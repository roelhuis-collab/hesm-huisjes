# HESM Dashboard env — copy to .env.local and fill in.
#
# Firebase web SDK config — these values are PUBLIC by design (they're
# embedded in the client bundle anyway). Security is enforced by
# Firestore rules + Firebase Auth allowed domains, not by hiding the key.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=hesm-huisjes.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=hesm-huisjes
VITE_FIREBASE_STORAGE_BUCKET=hesm-huisjes.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloud Run service URL — used for /chat and /override calls.
VITE_API_BASE_URL=https://hesm-optimizer-4rsk5dywaa-ez.a.run.app
